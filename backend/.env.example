# ─── Neon PostgreSQL (buradan al: https://neon.tech) ──────────────────────────
# Dashboard → your project → Connection string → copy the "postgresql://..." URL
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/treeban?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Üretimde bunu uzun, rastgele bir stringle değiştir:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=treeban-change-this-in-production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Vercel'e deploy ettikten sonra Vercel URL'ini buraya yaz:
FRONTEND_URL=http://localhost:5173

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
